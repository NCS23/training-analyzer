# ============================================
# Training Analyzer - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!

# ===== DATABASE =====
DATABASE_URL=postgresql://training_user:training_pass@localhost:5432/training_analyzer

# ===== AI PROVIDER CONFIGURATION =====

# Primary AI Provider (claude, ollama, openai)
AI_PRIMARY_PROVIDER=claude

# Fallback providers (comma-separated, in order of preference)
AI_FALLBACK_PROVIDERS=ollama,openai

# ----- Claude (Anthropic) -----
# Get API key from: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ----- Ollama (Self-hosted) -----
# Running locally or on NAS
OLLAMA_BASE_URL=http://192.168.68.66:11434
OLLAMA_MODEL=llama3.1:8b
# Other models: llama3.1:70b, mistral:7b, mixtral:8x7b

# ----- OpenAI (Optional) -----
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo

# ===== DOCLING OCR SERVER =====
# Your Docling server URL
DOCLING_SERVER_URL=http://192.168.68.66:5001

# ===== SECURITY =====
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== CORS =====
# Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== AI SETTINGS =====
AI_MAX_TOKENS_ANALYSIS=1000
AI_MAX_TOKENS_CHAT=2000
AI_MAX_TOKENS_REPORT=3000
AI_TEMPERATURE=0.3
AI_TIMEOUT=120

# ===== DEVELOPMENT =====
DEBUG=true
LOG_LEVEL=INFO

# ===== PRODUCTION =====
# Uncomment and configure for production deployment
# DATABASE_URL=postgresql://prod_user:prod_pass@prod_host:5432/training_analyzer_prod
# ALLOWED_ORIGINS=https://your-domain.com
# DEBUG=false
# LOG_LEVEL=WARNING

#!/usr/bin/env bash
# Git pre-push hook:
# 1. Block direct push to main
# 2. Require a completed workflow checklist
# 3. Validate design review report (when UI files changed)

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BRANCH=$(git branch --show-current 2>/dev/null)

# ============================================================
# 1. Block push to main
# ============================================================
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo ""
  echo "============================================"
  echo "  BLOCKED: Direct push to $BRANCH"
  echo "============================================"
  echo ""
  echo "  Use a feature branch and create a PR."
  echo ""
  exit 1
fi

# ============================================================
# 2. Check that workflow checklist exists and is complete
# ============================================================
CHECKLIST="${REPO_ROOT}/.claude/workflow-checklist.md"

if [ ! -f "$CHECKLIST" ]; then
  echo ""
  echo "============================================"
  echo "  BLOCKED: No workflow checklist found"
  echo "============================================"
  echo ""
  echo "  Create .claude/workflow-checklist.md with all steps marked [x]."
  echo ""
  exit 1
fi

# Count incomplete items BEFORE "Phase 4" (Phase 4 is post-push, can't be checked yet)
PRE_PUSH_SECTION=$(sed '/^## Phase 4/,$d' "$CHECKLIST")
INCOMPLETE=$(echo "$PRE_PUSH_SECTION" | grep -c '^\- \[ \]' 2>/dev/null || true)
INCOMPLETE=${INCOMPLETE:-0}
INCOMPLETE=$(echo "$INCOMPLETE" | tr -d '[:space:]')

if [ "$INCOMPLETE" -gt 0 ]; then
  echo ""
  echo "============================================"
  echo "  BLOCKED: Workflow checklist incomplete"
  echo "============================================"
  echo ""
  echo "  $INCOMPLETE unchecked items (Phase 0-3) in .claude/workflow-checklist.md:"
  echo ""
  echo "$PRE_PUSH_SECTION" | grep '^\- \[ \]'
  echo ""
  echo "  Complete all pre-push items before pushing."
  echo ""
  exit 1
fi

# ============================================================
# 3. Validate design review (when .tsx files are in the diff)
# ============================================================
# Check if any .tsx files changed compared to main
HAS_TSX=$(git diff main...HEAD --name-only 2>/dev/null | grep '\.tsx$' || true)

if [ -n "$HAS_TSX" ]; then
  echo "[pre-push] UI files changed — validating design review..."

  VALIDATE_SCRIPT="${REPO_ROOT}/scripts/validate-design-review.sh"

  if [ ! -x "$VALIDATE_SCRIPT" ]; then
    echo ""
    echo "============================================"
    echo "  BLOCKED: Design review validator not found"
    echo "============================================"
    echo ""
    echo "  Expected: scripts/validate-design-review.sh (executable)"
    echo ""
    exit 1
  fi

  if ! bash "$VALIDATE_SCRIPT"; then
    echo ""
    echo "============================================"
    echo "  BLOCKED: Design review validation failed"
    echo "============================================"
    echo ""
    echo "  Copy scripts/design-review-template.md to .claude/design-review.md"
    echo "  Fill out all sections, take a screenshot, set verdict to PASS."
    echo ""
    exit 1
  fi
fi

echo "[pre-push] All checks passed. Pushing..."
exit 0

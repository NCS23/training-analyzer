# ============================================
# Training Analyzer - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!

# ===== DATABASE =====
POSTGRES_USER=training_user
POSTGRES_PASSWORD=training_pass
POSTGRES_DB=training_analyzer
DATABASE_URL=postgresql+asyncpg://training_user:training_pass@postgres:5432/training_analyzer

# ===== AI PROVIDER CONFIGURATION =====

# Primary AI Provider (claude, ollama)
AI_PRIMARY_PROVIDER=claude

# Fallback providers (comma-separated, in order of preference)
AI_FALLBACK_PROVIDERS=ollama

# ----- Claude (Anthropic) -----
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ----- Ollama (Self-hosted) -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ===== SECURITY =====
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-minimum-32-characters-long

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== DEVELOPMENT =====
DEBUG=true
LOG_LEVEL=INFO
